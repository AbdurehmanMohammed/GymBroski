# Comma-separated browser origins allowed to call the API with credentials (cookies).
# Local Vite defaults are built in if unset. Production: your static site URL(s).
# CORS_ORIGIN=https://your-app.onrender.com

# Cookie SameSite: lax (default) for same-site / proxied dev. Use none for cross-site
# front-end + API (requires HTTPS and Secure cookies).
# COOKIE_SAMESITE=none
