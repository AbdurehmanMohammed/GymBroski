# Copy to .env and fill in values. Never commit .env (it is gitignored).

MONGO_URI=
PORT=5000
JWT_SECRET=

# Public site URL (email links, CORS-related expectations). Local dev: http://localhost:5173
# Production: use your real domain (email links, CORS). Dev: http://localhost:5173
APP_URL=https://gymbruski.com
APP_PUBLIC_NAME=Gym Broski

# Optional: Abstract Email API
# ABSTRACT_EMAIL_API_KEY=
# ABSTRACT_EMAIL_PRODUCT=reputation

# Optional: Resend (email) — after verifying gymbruski.com in Resend:
# RESEND_API_KEY=
# EMAIL_FROM="GymBruski Website <noreply@gymbruski.com>"

# Workout reminder cron (server/index.js). Set to false to disable.
# WORKOUT_REMINDER_CRON=false
